# MCP Client Environment Configuration
# Copy this file to .env and fill in your values

# Logging verbosity (DEBUG, INFO, WARNING, ERROR)
LOGGING_LEVEL="INFO"

# Google's Gemini (for ADK)
GOOGLE_GENAI_USE_VERTEXAI=True

## Option 1: Vertex AI (when GOOGLE_GENAI_USE_VERTEXAI=True)
GOOGLE_CLOUD_PROJECT="your-project-id"
GOOGLE_CLOUD_LOCATION="global"

## Option 2: API Key (when GOOGLE_GENAI_USE_VERTEXAI=False)
# GOOGLE_API_KEY="your-api-key"

# GCS bucket for media storage
GCS_BUCKET_NAME="your-bucket-name"

# ADK Session Service (Postgres, optional)
# Cloud SQL example:
# DB_CONNECTION_NAME="your-project:your-region:your-instance"
# SESSION_SERVICE_URI="postgresql+asyncpg://postgres:password@/postgres?host=/cloudsql/${DB_CONNECTION_NAME}"

# MCP Server Connection
# Connection type: `stdio` (local), `sse` (SSE), or `http` (Streamable HTTP)
SERVER_CONNECTION_TYPE="http"
# Server URL (used when SERVER_CONNECTION_TYPE is 'http' or 'sse')
SERVER_URL="http://localhost:8001"
