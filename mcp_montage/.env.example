# MCP Montage Server Environment Configuration
# Copy this file to .env and fill in your values

# Logging verbosity (DEBUG, INFO, WARNING, ERROR)
LOGGING_LEVEL="INFO"

# Use Vertex AI (True) or public Gemini API (False)
GOOGLE_GENAI_USE_VERTEXAI=True

# Google Cloud Project configuration (required for Vertex AI)
GOOGLE_CLOUD_PROJECT="your-project-id"
GOOGLE_CLOUD_LOCATION="global"

# API key for public Gemini API (required when GOOGLE_GENAI_USE_VERTEXAI is False)
# GOOGLE_API_KEY="your-api-key"

# GCS bucket for media storage
GCS_BUCKET_NAME="your-bucket-name"

# GCS folder containing ingredient/character images (optional)
GCS_INGREDIENT_IMAGES_FOLDER="gs://your-bucket-name/ingredient-images"

# Sign server URL for generating viewable links (optional)
# Leave unset to use authenticated GCS browser URLs
# VIEW_ENDPOINT="http://localhost:8080/view?uri="

# Path to service account JSON (optional, for non-ADC authentication)
# GOOGLE_APPLICATION_CREDENTIALS="path/to/service-account.json"
